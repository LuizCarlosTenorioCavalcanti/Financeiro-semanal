                        React.createElement('div', {className:'summary-value'}, fmt(totals.diferenca))
                    )
                ),
                React.createElement('h1', {style:{marginTop:24}}, 'Por Dia da Semana'),
                React.createElement('div', {className:'days-container'},
                    DIAS.filter(d => d !== 'Sábado' && d !== 'Domingo').map(dia=>{
                        const dayPagar = filtered.pagar.filter(i=>i['Dia da Semana']===dia);
                        const dayPago = filtered.pago.filter(i=>i['Dia da Semana']===dia);
                        if(!dayPagar.length&&!dayPago.length)return null;

                        const dayPagarTotal = dayPagar.reduce((s,i)=>s+(i['Apropriação Financeira']||0),0);
                        const dayPagoTotal = dayPago.reduce((s,i)=>s+(i['Apropriação Financeira']||0),0);
                        const dayDiff = dayPagarTotal - dayPagoTotal;
                        const dayDate = dayPagar[0]?.Data || dayPago[0]?.Data;
                        const dayKey = dia;
                        const isDayOpen = expanded[dayKey];
                        const empresas = [...new Set([...dayPagar.map(i=>i.Empreendimento), ...dayPago.map(i=>i.Empreendimento)])];

                        return React.createElement('div', {key:dia, className:'day-card'},
                            React.createElement('div', {className:'day-header', onClick:()=>toggle(dayKey)},
                                React.createElement('div', {className:'day-header-left'},
                                    React.createElement('span', {className:'arrow'}, isDayOpen?'▼':'▶'),
                                    React.createElement('div', null,
                                        React.createElement('div', {className:'day-title'}, dia),
                                        React.createElement('div', {className:'day-date'}, dayDate)
                                    )
                                ),
                                React.createElement('div', {className:'day-totals'},
                                    React.createElement('span', {className:'badge'},
                                        React.createElement('span', {className:'badge-label'}, 'A Pagar'),
                                        React.createElement('span', {className:'badge-value', style:{color:AZUL_DELTA}}, fmt(dayPagarTotal))
                                    ),
                                    React.createElement('span', {className:'badge'},
                                        React.createElement('span', {className:'badge-label'}, 'Pago'),
                                        React.createElement('span', {className:'badge-value', style:{color:'#16a34a'}}, fmt(dayPagoTotal))
                                    ),
                                    React.createElement('span', {className:'badge'},
                                        React.createElement('span', {className:'badge-label'}, 'Diferença'),
                                        React.createElement('span', {className:'badge-value', style:{color:dayDiff<0?'#dc2626':'#d97706'}}, fmt(dayDiff))
                                    )
                                )
                            ),
                            isDayOpen&&React.createElement('div', null,
                                empresas.map(empr=>{
                                    const emprPagar = dayPagar.filter(i=>i.Empreendimento===empr);
                                    const emprPago = dayPago.filter(i=>i.Empreendimento===empr);
                                    const emprPagarTotal = emprPagar.reduce((s,i)=>s+(i['Apropriação Financeira']||0),0);
                                    const emprPagoTotal = emprPago.reduce((s,i)=>s+(i['Apropriação Financeira']||0),0);
                                    const emprDiff = emprPagarTotal - emprPagoTotal;
                                    const emprKey = 'empr-'+empr;
                                    const isEmprOpen = expanded[emprKey];

                                    return React.createElement('div', {key:empr},
                                        React.createElement('div', {className:'empreendimento-header', onClick:()=>toggle(emprKey)},
                                            React.createElement('span', {className:'empreendimento-name'},
                                                React.createElement('span', {className:'arrow'}, isEmprOpen?'▼':'▶'),
                                                React.createElement('span', null, empr)
                                            ),
                                            React.createElement('div', {className:'empreendimento-totals'},
                                                React.createElement('div', {className:'empreendimento-total'},
                                                    React.createElement('span', {className:'total-label'}, 'A Pagar'),
                                                    React.createElement('span', {className:'total-value', style:{color:AZUL_DELTA}}, fmt(emprPagarTotal))
                                                ),
                                                React.createElement('div', {className:'empreendimento-total'},
                                                    React.createElement('span', {className:'total-label'}, 'Pago'),
                                                    React.createElement('span', {className:'total-value', style:{color:'#16a34a'}}, fmt(emprPagoTotal))
                                                ),
                                                React.createElement('div', {className:'empreendimento-total'},
                                                    React.createElement('span', {className:'total-label'}, 'Diferença'),
                                                    React.createElement('span', {className:'total-value', style:{color:emprDiff<0?'#dc2626':'#d97706'}}, fmt(emprDiff))
                                                )
                                            )
                                        ),
                                        isEmprOpen&&React.createElement('div', {style:{padding:'12px', background:'#f9fafb'}},
                                            (() => {
                                                const pagarGroups = {};
                                                const pagoGroups = {};
                                                emprPagar.forEach(i=>{if(!pagarGroups[i.Conjunto])pagarGroups[i.Conjunto]={};if(!pagarGroups[i.Conjunto][i.Definição])pagarGroups[i.Conjunto][i.Definição]=[];pagarGroups[i.Conjunto][i.Definição].push(i);});
                                                emprPago.forEach(i=>{if(!pagoGroups[i.Conjunto])pagoGroups[i.Conjunto]={};if(!pagoGroups[i.Conjunto][i.Definição])pagoGroups[i.Conjunto][i.Definição]=[];pagoGroups[i.Conjunto][i.Definição].push(i);});

                                                const allConjuntos = new Set([...Object.keys(pagarGroups), ...Object.keys(pagoGroups)]);
                                                const sortedConjuntos = [...allConjuntos].sort((a,b)=>{
                                                    const aTotal = (pagarGroups[a]?Object.values(pagarGroups[a]).reduce((s,arr)=>s+arr.reduce((v,i)=>v+(i['Apropriação Financeira']||0),0),0):0) - (pagoGroups[a]?Object.values(pagoGroups[a]).reduce((s,arr)=>s+arr.reduce((v,i)=>v+(i['Apropriação Financeira']||0),0),0):0);
                                                    const bTotal = (pagarGroups[b]?Object.values(pagarGroups[b]).reduce((s,arr)=>s+arr.reduce((v,i)=>v+(i['Apropriação Financeira']||0),0),0):0) - (pagoGroups[b]?Object.values(pagoGroups[b]).reduce((s,arr)=>s+arr.reduce((v,i)=>v+(i['Apropriação Financeira']||0),0),0):0);
                                                    return bTotal - aTotal;
                                                });

                                                const renderCol = (colName, colColor, isPago, isDiff) => {
                                                    return React.createElement('div', null,
                                                        React.createElement('div', {style:{fontSize:'11px', fontWeight:700, color:colColor, marginBottom:'8px', paddingBottom:'8px', borderBottom:'2px solid ' + colColor}}, colName),
                                                        sortedConjuntos.map(conj=>{
                                                            const conjKey = emprKey+'-'+conj;
                                                            const isConjOpen = expanded[conjKey];
                                                            const conjValPagar = pagarGroups[conj]?Object.values(pagarGroups[conj]).reduce((s,arr)=>s+arr.reduce((v,i)=>v+(i['Apropriação Financeira']||0),0),0):0;
                                                            const conjValPago = pagoGroups[conj]?Object.values(pagoGroups[conj]).reduce((s,arr)=>s+arr.reduce((v,i)=>v+(i['Apropriação Financeira']||0),0),0):0;
                                                            const conjValDiff = conjValPagar - conjValPago;
                                                            const conjVal = isDiff ? conjValDiff : (isPago ? conjValPago : conjValPagar);

                                                            const allDefs = new Set([...(pagarGroups[conj]?Object.keys(pagarGroups[conj]):[]), ...(pagoGroups[conj]?Object.keys(pagoGroups[conj]):[])]);
                                                            const sortedDefs = [...allDefs].sort((a,b)=>{
                                                                const aVal = (pagarGroups[conj]&&pagarGroups[conj][a]?pagarGroups[conj][a].reduce((s,i)=>s+(i['Apropriação Financeira']||0),0):0) - (pagoGroups[conj]&&pagoGroups[conj][a]?pagoGroups[conj][a].reduce((s,i)=>s+(i['Apropriação Financeira']||0),0):0);
                                                                const bVal = (pagarGroups[conj]&&pagarGroups[conj][b]?pagarGroups[conj][b].reduce((s,i)=>s+(i['Apropriação Financeira']||0),0):0) - (pagoGroups[conj]&&pagoGroups[conj][b]?pagoGroups[conj][b].reduce((s,i)=>s+(i['Apropriação Financeira']||0),0):0);
                                                                return bVal - aVal;
                                                            });

                                                            return React.createElement('div', {key:conj, style:{marginBottom:'4px'}},
                                                                React.createElement('button', {onClick:()=>toggle(conjKey), style:{width:'100%', textAlign:'left', background:'#f0f0f0', border:'none', cursor:'pointer', padding:'4px 6px', display:'flex', justifyContent:'space-between', alignItems:'center', fontSize:'10px', fontWeight:700, color:colColor, borderRadius:'3px', marginBottom:'2px'}},
                                                                    React.createElement('span', null, isConjOpen?'▼':'▶', ' ' + conj),
                                                                    React.createElement('span', null, fmt(conjVal))
                                                                ),
                                                                isConjOpen && sortedDefs.map(def=>{
                                                                    const defKey = conjKey+'-'+def;
                                                                    const isDefOpen = expanded[defKey];
                                                                    const defValPagar = pagarGroups[conj]&&pagarGroups[conj][def] ? pagarGroups[conj][def].reduce((s,i)=>s+(i['Apropriação Financeira']||0),0) : 0;
                                                                    const defValPago = pagoGroups[conj]&&pagoGroups[conj][def] ? pagoGroups[conj][def].reduce((s,i)=>s+(i['Apropriação Financeira']||0),0) : 0;
                                                                    const defValDiff = defValPagar - defValPago;
                                                                    const defVal = isDiff ? defValDiff : (isPago ? defValPago : defValPagar);

                                                                    const allItems = new Set([...(pagarGroups[conj]&&pagarGroups[conj][def]?pagarGroups[conj][def].map(i=>i['Código Apropriação']):[]), ...(pagoGroups[conj]&&pagoGroups[conj][def]?pagoGroups[conj][def].map(i=>i['Código Apropriação']):[])]);
                                                                    const sortedItems = [...allItems].sort((a,b)=>{
                                                                        const aVal = (pagarGroups[conj]&&pagarGroups[conj][def]?pagarGroups[conj][def].find(i=>i['Código Apropriação']===a)?.['Apropriação Financeira']||0:0);
                                                                        const bVal = (pagarGroups[conj]&&pagarGroups[conj][def]?pagarGroups[conj][def].find(i=>i['Código Apropriação']===b)?.['Apropriação Financeira']||0:0);
                                                                        return bVal - aVal;
                                                                    });

                                                                    return React.createElement('div', {key:def, style:{marginLeft:'6px', marginBottom:'3px'}},
                                                                        React.createElement('button', {onClick:()=>toggle(defKey), style:{width:'100%', textAlign:'left', background:'#f9f9f9', border:'none', cursor:'pointer', padding:'3px 6px', display:'flex', justifyContent:'space-between', alignItems:'center', fontSize:'9px', fontWeight:600, color:colColor, borderRadius:'2px', marginBottom:'1px'}},
                                                                            React.createElement('span', null, isDefOpen?'▼':'▶', ' ' + def),
                                                                            React.createElement('span', null, fmt(defVal))
                                                                        ),
                                                                        isDefOpen && sortedItems.map((codigo, ix)=>{
                                                                            const item = pagarGroups[conj]&&pagarGroups[conj][def] ? pagarGroups[conj][def].find(i=>i['Código Apropriação']===codigo) : (pagoGroups[conj]&&pagoGroups[conj][def] ? pagoGroups[conj][def].find(i=>i['Código Apropriação']===codigo) : null);
                                                                            const itemValPagar = pagarGroups[conj]&&pagarGroups[conj][def] ? (pagarGroups[conj][def].find(p=>p['Código Apropriação']===codigo)?.['Apropriação Financeira'])||0 : 0;
                                                                            const itemValPago = pagoGroups[conj]&&pagoGroups[conj][def] ? (pagoGroups[conj][def].find(p=>p['Código Apropriação']===codigo)?.['Apropriação Financeira'])||0 : 0;
                                                                            const itemValDiff = itemValPagar - itemValPago;
                                                                            const itemVal = isDiff ? itemValDiff : (isPago ? itemValPago : itemValPagar);
                                                                            const nome = item?.['Nome Apropriação'] || '';

                                                                            return React.createElement('div', {key:ix, style:{marginLeft:'12px', fontSize:'8px', padding:'2px 6px', borderBottom:'1px solid #e0e0e0', display:'flex', justifyContent:'space-between', gap:'4px'}},
                                                                                React.createElement('span', {style:{fontWeight:600, color:'#1B5BA4', minWidth:'50px'}}, codigo),
                                                                                React.createElement('span', {style:{flex:1, color:'#666', textAlign:'center'}}, nome),
                                                                                React.createElement('span', {style:{fontWeight:600, textAlign:'right', minWidth:'60px', color:itemVal===0?'#999':(itemVal<0?'#dc2626':colColor), fontWeight:itemVal===0?400:600}}, fmt(itemVal))
                                                                            );
                                                                        })
                                                                    );
                                                                })
                                                            );
                                                        })
                                                    );
                                                };

                                                return React.createElement('div', {style:{display:'grid', gridTemplateColumns:'repeat(auto-fit, minmax(200px, 1fr))', gap:'8px', padding:'0'}},
                                                    renderCol('A PAGAR', AZUL_DELTA, false, false),
                                                    renderCol('PAGO', '#16a34a', true, false),
                                                    renderCol('DIFERENÇA', '#d97706', false, true)
                                                );
                                            })()
                                        )
                                    );
                                })
                            )
                        );
                    })
                )
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(React.createElement(App));
    </script>
</body>
</html>
